# GEMINI_API_KEY: Required for Gemini AI API calls (Image to Prompt tool).
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel, add this to your Environment Variables.
GEMINI_API_KEY=

# APP_URL: The URL where this app is hosted.
# Used for generating shareable links in the "Image to URL" tool.
# On Vercel, use your deployment URL (e.g., https://your-app.vercel.app).
APP_URL=

# SESSION_SECRET: A random string used to sign session cookies.
# Keep this secret and unique for your production environment.
SESSION_SECRET=
